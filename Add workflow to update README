import sys

class Tee:
    def __init__(self, *files):
        self.files = files

    def write(self, data):
        for f in self.files:
            f.write(data)

    def flush(self):
        for f in self.files:
            f.flush()

repo_name = "my-repo"
output_file = f"{repo_name}_results.txt"

log = open(output_file, "w", encoding="utf-8")
sys.stdout = Tee(sys.stdout, log)

print("دي نتيجة 1")
print("دي نتيجة 2")

log.close()